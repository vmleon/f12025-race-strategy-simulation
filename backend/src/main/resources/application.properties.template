spring.application.name=backend
server.port=8080

spring.datasource.type=oracle.ucp.jdbc.PoolDataSourceImpl
spring.datasource.url=jdbc:oracle:thin:@${ORACLE_HOST:localhost}:${ORACLE_PORT:1521}/FREEPDB1
spring.datasource.username=pdbadmin
spring.datasource.password={{DB_PASSWORD}}
spring.datasource.driver-class-name=oracle.jdbc.OracleDriver
spring.datasource.oracleucp.connection-factory-class-name=oracle.jdbc.pool.OracleDataSource
# Fix C from the GP postmortem: lazy init so the backend doesn't burn through
# failed-login attempts when started before the PDB is fully open. The pool
# was previously eager (initial=2, min=2) — every retry counted toward the
# default profile's FAILED_LOGIN_ATTEMPTS=10 and locked pdbadmin in seconds.
spring.datasource.oracleucp.initial-pool-size=0
spring.datasource.oracleucp.min-pool-size=0
spring.datasource.oracleucp.max-pool-size=10
spring.datasource.oracleucp.connection-wait-duration=30s
spring.datasource.oracleucp.validate-connection-on-borrow=true

telemetry.tcp.port=9090

# Race-engineer radio LLM (vLLM). Phase 1 ships a passthrough renderer that
# ignores host/port/model and logs them at startup; timeout-ms bounds the
# (future) render call and falls back to the templated text.
engineer.llm.host=localhost
engineer.llm.port=8000
engineer.llm.model=meta-llama/Llama-3.1-8B-Instruct
engineer.llm.timeout-ms=500
